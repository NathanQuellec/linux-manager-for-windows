<UserControl x:Class="LinuxManager.Views.UserControls.DisplaySnapshotsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="using:LinuxManager.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:system="using:System"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="400"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <!-- DataContext expected: Distribution -->
    <Border CornerRadius="8"
            Padding="20"
            Background="{ThemeResource LayerFillColorAltBrush}"
            BorderBrush="{ThemeResource SubtleBorderBrush}"
            BorderThickness="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Column="0"
                  Grid.Row="0"
                  ColumnSpacing="16"
                  Margin="0 0 12 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Snapshot Management"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"
                           Grid.Row="0"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                <Button Grid.Column="1"
                        HorizontalAlignment="Right"
                        Width="144"
                        Height="28"
                        VerticalAlignment="Top"
                        Style="{StaticResource AccentButtonStyle}"
                        CornerRadius="4"
                        Command="{x:Bind CreateSnapshotCommand, Mode=OneWay}"
                        CommandParameter="{x:Bind DataContext, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE710;"
                                  FontSize="10"
                                  FontWeight="Bold" />
                        <TextBlock Text="Create Snapshot"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Right"
                        Width="144"
                        Height="28"
                        VerticalAlignment="Top"
                        Style="{StaticResource AccentButtonStyle}"
                        CornerRadius="4"
                        Click="OpenSnapshotsFolder">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE8A7;"
                                  FontSize="10"
                                  FontWeight="Bold" />
                        <TextBlock Text="Open Folder"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Column="0"
                  Grid.Row="1">
                <StackPanel x:Name="SnapshotsEmptyStatePanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,12,0,0">
                    <FontIcon Glyph="&#xE8B3;"
                              FontSize="28"
                              Foreground="{ThemeResource SystemColorGrayTextColor}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No Snapshots Yet"
                               FontWeight="SemiBold"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Create your first snapshot to save the current state of this distribution"
                               FontSize="12"
                               Foreground="{ThemeResource SystemColorGrayTextColor}"
                               TextAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>

                <ListView x:Name="SnapshotsListView"
                          ItemsSource="{Binding Snapshots, Mode=TwoWay}"
                          Margin="0 16 0 0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Visibility="Collapsed"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.VerticalScrollMode="Enabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:Snapshot">
                            <Border CornerRadius="6"
                                    BorderBrush="{ThemeResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0 0 0 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="8"
                                            Background="{ThemeResource SystemAccentColorDark2}"
                                            BorderBrush="{ThemeResource SubtleBorderBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE722;"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"
                                                  FontSize="16"
                                                  Foreground="{ThemeResource SystemAccentColorLight1}" />
                                    </Border>
                                    <Grid Grid.Column="1"
                                          Margin="12,0,0,0"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <Border Padding="6,2"
                                                    Margin="8,0,0,0"
                                                    CornerRadius="2"
                                                    VerticalAlignment="Center"
                                                    BorderBrush="{ThemeResource SubtleBorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{x:Bind system:String.Format('{0} GB', Size)}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource SystemControlBackgroundBaseHighBrush}" />
                                            </Border>
                                        </StackPanel>


                                        <StackPanel  Grid.Column="0"
                                                     Grid.Row="1"
                                                     Orientation="Horizontal"
                                                     VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE787;"
                                                      FontSize="12"
                                                      Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                      Margin="0,0,6,0" />
                                            <TextBlock Text="{x:Bind CreationDate}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource SystemColorGrayTextColor}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Grid.Row="1"
                                                   Text="{x:Bind Description}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                   VerticalAlignment="Stretch"
                                                   HorizontalAlignment="Stretch"
                                                   TextWrapping="WrapWholeWords"
                                                   Margin="8 0 0 0"/>
                                    </Grid>
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <Button Style="{StaticResource MinimalistButtonStyle}"
                                                ToolTipService.ToolTip="Create Distribution"
                                                Click="OpenCreateDistroDialog">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <FontIcon Glyph="&#xE72D;"
                                                          FontSize="16" />
                                                <TextBlock Text="Create Distribution"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource MinimalistButtonStyle}"
                                                ToolTipService.ToolTip="Delete"
                                                Click="OpenDeleteSnapshotDialog">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <FontIcon Glyph="&#xE74D;"
                                                          Foreground="{ThemeResource DeleteButton}"
                                                          FontSize="16" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Border>
</UserControl>
