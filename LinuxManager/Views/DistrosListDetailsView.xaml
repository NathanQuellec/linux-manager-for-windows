<Page x:Name="Page"
      x:Class="LinuxManager.Views.DistrosListDetailsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:model="using:LinuxManager.Models"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:userControls="using:LinuxManager.Views.UserControls"
      xmlns:system="using:System"
      xmlns:templateSelector="using:LinuxManager.Views.TemplateSelector"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="AppTitleBar"
                    Orientation="Horizontal"
                    Grid.Row="0"
                    BorderBrush="{ThemeResource SubtleBorderBrush}"
                    BorderThickness="0 1 0 1">
            <Image Source="/Assets/LinuxManagerIcon.ico"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Width="20"
                   Height="20"
                   Margin="8,6, 4, 4" />
            <TextBlock x:Name="AppTitleTextBlock"
                       Text="Linux Manager"
                       TextWrapping="NoWrap"
                       FontWeight="SemiBold"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="4,4,0,4" />
        </StackPanel>

        <SplitView Grid.Row="1"
                   DisplayMode="Inline"
                   IsPaneOpen="True"
                   OpenPaneLength="300"
                   Margin="0 0 0 0"
                   PaneBackground="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                   BorderThickness="0 0 1 0"
                   BorderBrush="{ThemeResource SubtleBorderBrush}">

            <!-- Master List (Pane) -->
            <SplitView.Pane>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Spacing="16"
                                BorderThickness="0 0 0 1"
                                BorderBrush="{ThemeResource SubtleBorderBrush}">
                        <StackPanel Margin="20 0 0 0">
                            <TextBlock Text="WSL Distributions"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       Margin="0 16 0 0" />
                            <TextBlock Text="Manage your Linux environments"
                                       FontSize="10"
                                       Foreground="{ThemeResource SystemColorGrayTextColor}" />
                        </StackPanel>

                        <Button Content="+  Install Distribution"
                                HorizontalAlignment="Stretch"
                                Height="28"
                                Style="{StaticResource AccentButtonStyle}"
                                CornerRadius="4"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Margin="20 0 20 16"
                                Command="{Binding ElementName=Page, Path=ViewModel.CreateDistroCommand}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="180"
                                Margin="20 8 0 0">
                        <TextBlock Text="DISTRIBUTIONS"
                                   FontSize="10"
                                   FontWeight="Medium"
                                   Foreground="{ThemeResource SystemColorGrayTextColor}" />

                        <TextBlock Text="{Binding ElementName=Page, Path=ViewModel.Distros.Count, Mode=TwoWay}"
                                   FontSize="10"
                                   Foreground="{ThemeResource SystemColorGrayTextColor}" />

                    </StackPanel>

                    <ListView x:Name="MasterListView"
                              Grid.Row="2"
                              IsItemClickEnabled="True"
                              SelectionMode="Single"
                              ItemsSource="{x:Bind Path=ViewModel.Distros, Mode=TwoWay}">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:Distribution">
                                <StackPanel BorderThickness="1"
                                            Height="80">
                                    <StackPanel.Resources>
                                        <MenuFlyout x:Key="DistroMenuFlyout">

                                            <MenuFlyoutItem Text="Browse Files"
                                                            Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroWithFileExplorerCommand}"
                                                            CommandParameter="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xEC50;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>

                                            <MenuFlyoutItem Text="VS Code"
                                                            Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroWithVsCodeCommand}"
                                                            CommandParameter="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE943;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>

                                            <MenuFlyoutItem Text="Terminal"
                                                            Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroWithWinTermCommand}"
                                                            CommandParameter="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE756;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>

                                            <MenuFlyoutItem Text="Delete"
                                                            Foreground="{ThemeResource DeleteButton}"
                                                            Command="{Binding ElementName=Page, Path=ViewModel.RemoveDistroCommand}"
                                                            CommandParameter="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74D;"
                                                              Foreground="{ThemeResource DeleteButton}" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>

                                        </MenuFlyout>
                                    </StackPanel.Resources>

                                    <RelativePanel ContextFlyout="{StaticResource DistroMenuFlyout}"
                                                   Height="80"
                                                   BorderThickness="1"
                                                   VerticalAlignment="Center"
                                                   Margin="0 8 0 12">

                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="Right-Click" />
                                        </ToolTipService.ToolTip>

                                        <!-- Launch Button with unique tag -->
                                        <Button x:Name="LaunchButton"
                                                Style="{StaticResource MinimalistButtonStyle}"
                                                Tag="{x:Bind Path=system:String.Format('START_{0}', Name), Mode=OneWay}"
                                                Margin="0 12 0 0"
                                                Command="{Binding ElementName=Page, Path=ViewModel.LaunchDistroCommand}"
                                                CommandParameter="{x:Bind}">
                                            <FontIcon Glyph="&#xE768;"
                                                      FontSize="24" />
                                        </Button>

                                        <!-- Stop Button with unique tag -->
                                        <Button x:Name="StopButton"
                                                RelativePanel.RightOf="LaunchButton"
                                                Style="{StaticResource MinimalistButtonStyle}"
                                                Tag="{x:Bind Path=system:String.Format('STOP_{0}', Name), Mode=OneWay}"
                                                Visibility="Collapsed"
                                                Margin="0 12 0 0"
                                                Command="{Binding ElementName=Page, Path=ViewModel.StopDistroCommand}"
                                                CommandParameter="{x:Bind}">
                                            <SymbolIcon Symbol="Stop"
                                                        Height="24"
                                                        Width="24" />
                                        </Button>

                                        <!-- Distro info replaced: use Grid to occupy remaining space to the right -->
                                        <Grid RelativePanel.RightOf="StopButton"
                                              RelativePanel.AlignRightWithPanel="True"
                                              HorizontalAlignment="Stretch"
                                              Margin="4 12 0 0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="DistroName"
                                                       Grid.Row="0"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Text="{x:Bind Name, Mode=TwoWay}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Margin="4 0 0 4" />
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                               Text="{x:Bind OsName, Mode=TwoWay}"
                                                               FontSize="8"
                                                               VerticalAlignment="Center"
                                                               Margin="4 0 6 0" />
                                                    <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                               Text="{x:Bind OsVersion, Mode=TwoWay}"
                                                               FontSize="8"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right">
                                                    <StackPanel Orientation="Horizontal"
                                                                Visibility="Collapsed"
                                                                Tag="{x:Bind Path=system:String.Format('RUNNING_{0}', Name), Mode=OneWay}">
                                                        <FontIcon Glyph="&#xEA81;"
                                                                  FontSize="12"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="ForestGreen"
                                                                  Margin="12 0 4 4" />
                                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                                                                   Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                                   Text="Running"
                                                                   FontSize="8"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal"
                                                                Tag="{x:Bind Path=system:String.Format('STOPPED_{0}', Name), Mode=OneWay}">
                                                        <FontIcon Glyph="&#xEA81;"
                                                                  FontSize="12"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="Gray"
                                                                  Margin="12 0 4 4" />
                                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                                                                   Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                                   Text="Stopped"
                                                                   FontSize="8"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </RelativePanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </SplitView.Pane>

            <!-- Detail Content -->
            <SplitView.Content>
                <ContentControl x:Name="DetailContent"
                                Content="{x:Bind MasterListView.SelectedItem, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">

                    <ContentControl.Resources>
                        <!-- Default template -->
                        <DataTemplate x:Key="DefaultContentTemplate">
                            <Grid>
                                <Grid HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <TextBlock Text="Select a distribution to view details"
                                               FontSize="24"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource SystemColorGrayTextColor}" />
                                </Grid>
                            </Grid>
                        </DataTemplate>

                        <!-- Distribution detail template : layout en cartes -->
                        <DataTemplate x:Key="DistributionTemplate"
                                      x:DataType="model:Distribution">
                            <Grid Padding="16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <!-- Header -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Top cards: Storage & Snapshots -->
                                    <RowDefinition Height="Auto" />
                                    <!-- System information -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Quick actions -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Snapshot management (fills remaining space) -->
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Header : Icon, Name, subtitle and actions -->
                                <Grid Grid.Row="0"
                                      Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Icon -->
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="8"
                                            Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                            BorderBrush="{ThemeResource SubtleBorderBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE770;"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind OsName}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource SystemColorGrayTextColor}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Top cards row : Storage & Snapshots -->
                                <Grid Grid.Row="1"
                                      ColumnSpacing="16"
                                      Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Storage card -->
                                    <Border Grid.Column="0"
                                            CornerRadius="8"
                                            Padding="16"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            BorderBrush="{ThemeResource SubtleBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Storage"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource SystemColorGrayTextColor}" />
                                            <TextBlock Text="{x:Bind Path=system:String.Format('{0} GB', DiskUsageInfo.Used)}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Margin="0,8,0,4" />
                                            <ProgressBar Value="{x:Bind Path=DiskUsageInfo.UsePercentage}"
                                                         Maximum="100"
                                                         Height="8"
                                                         Margin="0,4,8,4"
                                                         Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Path=system:String.Format('{0}% used', DiskUsageInfo.UsePercentage)}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                           Margin="0,8,4,0" />
                                                <TextBlock Text="{x:Bind Path=system:String.Format('of {0} GB', DiskUsageInfo.Size)}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource SystemColorGrayTextColor}"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <!-- Snapshots card -->
                                    <Border Grid.Column="1"
                                            CornerRadius="8"
                                            Padding="16"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            BorderBrush="{ThemeResource SubtleBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Snapshots"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource SystemColorGrayTextColor}" />
                                            <TextBlock Text="{x:Bind Snapshots.Count, Mode=OneWay}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Margin="0,8,0,4" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- System information card -->
                                <Border Grid.Row="2"
                                        CornerRadius="8"
                                        Margin="0,0,0,20"
                                        Padding="16"
                                        Background="{ThemeResource LayerFillColorAltBrush}"
                                        BorderBrush="{ThemeResource SubtleBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="System Information"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,12" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Installation location -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Installation Location"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource SystemColorGrayTextColor}" />
                                                <Border Padding="8"
                                                        Margin="0,8,0,0"
                                                        CornerRadius="6"
                                                        BorderBrush="{ThemeResource SubtleBorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <Button Style="{StaticResource MinimalistButtonStyle}"
                                                                ToolTipService.ToolTip="Open folder"
                                                                Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroInstallationLocationCommand}"
                                                                CommandParameter="{x:Bind}">
                                                            <FontIcon Glyph="&#xED25;" />
                                                        </Button>
                                                        <TextBlock Text="{x:Bind Path}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12" 
                                                                   Margin="0 8 0 0"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Quick actions -->
                                <Border Grid.Row="3"
                                        CornerRadius="8"
                                        Margin="0,0,0,20"
                                        Padding="12"
                                        Background="{ThemeResource LayerFillColorAltBrush}"
                                        BorderBrush="{ThemeResource SubtleBorderBrush}"
                                        BorderThickness="1">

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="120"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Margin="20 0 20 0">
                                        <Button Style="{StaticResource MinimalistButtonStyle}"
                                                Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroWithWinTermCommand}"
                                                CommandParameter="{x:Bind}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <FontIcon Glyph="&#xE756;" />
                                                <TextBlock Text="Terminal"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource MinimalistButtonStyle}"
                                                Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroWithVsCodeCommand}"
                                                CommandParameter="{x:Bind}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <FontIcon Glyph="&#xE943;" />
                                                <TextBlock Text="Visual Studio Code"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource MinimalistButtonStyle}"
                                                Command="{Binding ElementName=Page, Path=ViewModel.OpenDistroWithFileExplorerCommand}"
                                                CommandParameter="{x:Bind}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <FontIcon Glyph="&#xEC50;" />
                                                <TextBlock Text="Browse Files"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                        <Button Width="140"
                                                Height="36"
                                                Background="{ThemeResource DeleteButton}"
                                                Foreground="White"
                                                CornerRadius="6"
                                                Command="{Binding ElementName=Page, Path=ViewModel.RemoveDistroCommand}"
                                                CommandParameter="{x:Bind}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8"
                                                        HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE74D;"
                                                          FontSize="12" />
                                                <TextBlock Text="Delete"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Snapshot management area -->
                                <userControls:DisplaySnapshotsView Grid.Row="4"
                                                                   HorizontalAlignment="Stretch"
                                                                   VerticalAlignment="Stretch"
                                                                   DataContext="{Binding}"
                                                                   CreateSnapshotCommand="{Binding ElementName=Page, Path=ViewModel.CreateSnapshotCommand}" />
                            </Grid>
                        </DataTemplate>

                    </ContentControl.Resources>

                    <ContentControl.ContentTemplateSelector>
                        <templateSelector:DistributionTemplateSelector DefaultTemplate="{StaticResource DefaultContentTemplate}"
                                                                       DistributionTemplate="{StaticResource DistributionTemplate}" />
                    </ContentControl.ContentTemplateSelector>
                </ContentControl>
            </SplitView.Content>
        </SplitView>

        <userControls:WslProcessInfoBar x:Name="WslProcessInfoBar"
                                        Grid.Row="1" />

    </Grid>
</Page>
